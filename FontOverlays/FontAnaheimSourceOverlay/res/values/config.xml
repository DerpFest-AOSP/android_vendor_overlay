<resources>
    <!-- Name of a font family to use for body text. -->
    <string name="config_bodyFontFamily" translatable="false">anaheim</string>
    <!-- Name of a font family to use for medium body text. -->
    <string name="config_bodyFontFamilyMedium" translatable="false">anaheim-medium</string>
    <!-- Name of a font family to use for headlines. If empty, falls back to platform default -->
    <string name="config_headlineFontFamily" translatable="false">anaheim</string>
    <!-- Name of the font family used for system surfaces where the font should use medium weight -->
    <string name="config_headlineFontFamilyMedium" translatable="false">anaheim-medium</string>
    <!-- Name of a font family to use as light font. For theming purpose. -->
    <string name="config_lightFontFamily" translatable="false">anaheim</string>
    <!-- Name of a font family to use as regular font. For theming purpose. -->
    <string name="config_regularFontFamily" translatable="false">anaheim</string>

    <!-- Emphasized font families for Material typography -->
    <string name="config_displayLargeEmphasizedFontFamily" translatable="false">anaheim</string>
    <string name="config_displayMediumEmphasizedFontFamily" translatable="false">anaheim</string>
    <string name="config_displaySmallEmphasizedFontFamily" translatable="false">anaheim</string>
</resources>
